#!/bin/bash

# Navigate to script directory
cd "$(dirname "$0")"

# Function to find suitable Python version
find_python() {
    for version in python3.13 python3.12 python3.11; do
        if command -v $version &> /dev/null; then
            echo $version
            return 0
        fi
    done
    return 1
}

# Check if virtual environment exists and is functional
if [ ! -f ".venv/bin/wu" ]; then
    echo "Setting up environment..."

    # Find suitable Python version
    PYTHON=$(find_python)
    if [ $? -ne 0 ]; then
        echo "Error: Python 3.11+ required but not found."
        echo "Please install Python 3.11 or higher first."
        exit 1
    fi

    echo "Using $PYTHON"

    # Remove old venv if it exists
    [ -d ".venv" ] && rm -rf .venv

    # Create new virtual environment
    $PYTHON -m venv .venv

    # Activate and install
    source .venv/bin/activate
    pip install --upgrade pip -q
    pip install -e . -q

    echo "Environment ready!"
fi

# Activate virtual environment and run wu
source .venv/bin/activate
wu "$@"
