# Copy to .env and chmod 600
# cp .env.example .env && chmod 600 .env

# === Laravel Cloud ===
# Generate at https://cloud.laravel.com/ → Account Settings → API Tokens
LARAVEL_CLOUD_API_TOKEN=

# Base URL — override if needed. Default is a guess; confirm against
# https://cloud.laravel.com/docs/api/introduction and adjust.
LARAVEL_CLOUD_API_BASE=https://cloud.laravel.com/api/v1

# === SMTP / email reports ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=1
MAIL_FROM=websiteupdater <reports@example.com>
MAIL_TO=you@example.com

# === Misc ===
# Show a macOS notification on failure in addition to emailing
NOTIFY_MACOS=1

# Keep ephemeral environments after failed runs for debugging (0 or 1)
KEEP_FAILED_ENVS=0

# Polling interval (seconds) and timeout (seconds) for Laravel Cloud deploys
LC_POLL_INTERVAL=10
LC_ENV_CREATE_TIMEOUT=300
LC_DEPLOY_TIMEOUT=900

# Playwright viewport
SCREENSHOT_WIDTH=1440
SCREENSHOT_HEIGHT=900

# Playwright navigation timeout (milliseconds)
PLAYWRIGHT_NAVIGATION_TIMEOUT=45000
# Playwright post-mask wait (milliseconds) for CSS to apply
PLAYWRIGHT_MASK_WAIT=250

# Artifact retention: keep runs from last N days (0 = keep forever)
ARTIFACT_RETENTION_DAYS=30

# === Binary paths ===
# Full paths to composer and npm binaries (for launchd/cron compatibility)
COMPOSER_BIN=/opt/homebrew/bin/composer
NPM_BIN=/opt/homebrew/bin/npm

# === Workspace ===
# Default directory for project checkouts (defaults to ~/dev)
WORKSPACE_DIR=~/dev
